{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "warn",
    "suspicious": "warn"
  },
  "rules": {
    "react/exhaustive-deps": "off",
    "typescript/no-explicit-any": "off"
  },
  "plugins": ["oxc", "typescript", "unicorn", "react"],
  "settings": {
    "react": {
      "version": null,
      "linkComponents": [],
      "formComponents": [],
      "componentWrapperFunctions": []
    }
  }
}
