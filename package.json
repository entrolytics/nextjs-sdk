{
  "name": "@entrolytics/nextjs-sdk",
  "version": "2.2.0",
  "description": "Next.js SDK for Entrolytics - First-party growth analytics for the edge",
  "keywords": [
    "analytics",
    "deployment-tracking",
    "entrolytics",
    "form-analytics",
    "nextjs",
    "privacy",
    "react",
    "tracking",
    "web-analytics",
    "web-vitals"
  ],
  "homepage": "https://entrolytics.click",
  "bugs": {
    "url": "https://github.com/entrolytics/nextjs-sdk/issues"
  },
  "license": "MIT",
  "author": "Entrolytics <hey@entrolytics.click>",
  "repository": {
    "type": "git",
    "url": "https://github.com/entrolytics/nextjs-sdk.git",
    "directory": "entro-nextjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js",
      "require": "./dist/plugin/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint --fix . && oxfmt --write .",
    "lint:check": "oxlint . && oxfmt --check .",
    "lint:fix-unsafe": "oxlint -f stylish --import-plugin --type-aware --type-check --vitest-plugin --fix --fix-suggestions --fix-dangerously src/",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@entrolytics/shared": "^2.4.0",
    "@entrolytics/trpc-client": "^2.2.2",
    "@tanstack/react-query": "^5.95.2",
    "@trpc/client": "^11.15.1",
    "@trpc/next": "^11.15.1",
    "@trpc/react-query": "^11.15.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "next": "^16.2.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsdown": "^0.21.6",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "web-vitals": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "web-vitals": "^5.2.0"
  },
  "engines": {
    "node": ">=24.x"
  },
  "packageManager": "pnpm@10.33.0"
}
